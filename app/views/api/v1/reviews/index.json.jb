# frozen_string_literal: true

@api_v1_reviews.map do |api_v1_review|
  {
    id: api_v1_review.id,
    account_id: api_v1_review.account_id,
    restaurant_id: api_v1_review.restaurant_id,
    order_id: api_v1_review.order_id,
    rating: api_v1_review.rating,
    comment: api_v1_review.comment,
    url: api_v1_review_url(api_v1_review, format: :json)
  }
end
