@api_v1_menu_items.map do |api_v1_menu_item|
  {
    id: api_v1_menu_item.id,
    restaurant_id: api_v1_menu_item.restaurant_id,
    category: api_v1_menu_item.category,
    name: api_v1_menu_item.name,
    description: api_v1_menu_item.description,
    price: api_v1_menu_item.price,
    is_available: api_v1_menu_item.is_available,
    url: api_v1_menu_item_url(api_v1_menu_item, format: :json)
  }
end
